FLASK_SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=false
SESSION_TIMEOUT_MINUTES=60
REMEMBER_ME_DAYS=7
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
ALLOW_DEV_ADMIN_SETUP=true
FILE_RETENTION_HOURS=12
RUN_RETENTION_DAYS=60

# Use a Fernet key. Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=replace-with-fernet-key

APP_ADMIN_USER=admin
# Generate hash with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
APP_ADMIN_PASSWORD_HASH=replace-with-password-hash

UNIPASS_URL=https://external.unipassghana.com/login/login.do
MAX_RETRIES=2
DEFAULT_PAGE_SIZE=30
OUTPUT_DIR=reports
EDGE_DRIVER_PATH=C:/WebDriver/msedgedriver.exe
SCREENSHOT_DIR=screenshots
# For Vercel, use a writable temp path: SCREENSHOT_DIR=/tmp/screenshots
DB_BACKEND=sqlite
DATABASE_PATH=app.db

# Set these only when DB_BACKEND=turso
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Turso mode also requires:
# FLASK_SECRET_KEY to be non-placeholder
# APP_ADMIN_PASSWORD_HASH to be a real hash
# SESSION_COOKIE_SECURE=true

# Optional defaults for dashboard date fields
DEFAULT_START_DATE=
DEFAULT_END_DATE=
